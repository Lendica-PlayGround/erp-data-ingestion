{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erp-data-ingestion/schemas/midlayer/v1/invoice.schema.json",
  "title": "MidLayer Invoice v1",
  "description": "Canonical mid-layer Invoice schema, aligned with merge.dev Accounting Invoice common model. Monetary values are stored in major units (e.g. dollars), never cents. Timestamps are ISO 8601 UTC with Z suffix.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "external_id",
    "_source_system",
    "_source_record_id",
    "_company_id",
    "_ingested_at",
    "_source_file",
    "_mapping_version",
    "_row_hash"
  ],
  "properties": {
    "external_id": {
      "type": "string",
      "description": "Stable, source-provided identifier. For Stripe, the raw id with prefix preserved (e.g. 'in_1Abc...')."
    },
    "type": {
      "type": ["string", "null"],
      "enum": ["ACCOUNTS_RECEIVABLE", "ACCOUNTS_PAYABLE", null],
      "description": "merge.dev Invoice.type enum."
    },
    "number": {
      "type": ["string", "null"],
      "description": "Human-readable invoice number (e.g. 'INV-0001')."
    },
    "contact_external_id": {
      "type": ["string", "null"],
      "description": "External id of the linked Customer/Contact."
    },
    "issue_date": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp. Null when unknown."
    },
    "due_date": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "paid_on_date": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "memo": {
      "type": ["string", "null"]
    },
    "currency": {
      "type": ["string", "null"],
      "description": "ISO-4217 currency code, uppercase.",
      "pattern": "^[A-Z]{3}$"
    },
    "exchange_rate": {
      "type": ["string", "null"],
      "description": "Decimal string; null if not provided."
    },
    "total_discount": {
      "type": ["string", "null"],
      "description": "Decimal string in major units."
    },
    "sub_total": {
      "type": ["string", "null"],
      "description": "Decimal string in major units."
    },
    "total_tax_amount": {
      "type": ["string", "null"],
      "description": "Decimal string in major units."
    },
    "total_amount": {
      "type": ["string", "null"],
      "description": "Decimal string in major units."
    },
    "balance": {
      "type": ["string", "null"],
      "description": "Decimal string in major units; outstanding amount."
    },
    "status": {
      "type": ["string", "null"],
      "enum": [
        "DRAFT",
        "OPEN",
        "PAID",
        "UNCOLLECTIBLE",
        "VOID",
        "PARTIALLY_PAID",
        "SUBMITTED",
        null
      ]
    },
    "remote_was_deleted": {
      "type": "boolean",
      "default": false
    },
    "_unmapped": {
      "type": ["string", "null"],
      "description": "Minified JSON object preserving source columns the mapper could not map."
    },
    "_source_system": {
      "type": "string",
      "description": "Slug identifying source system (e.g. 'stripe', 'google_sheets')."
    },
    "_source_record_id": {
      "type": "string",
      "description": "Raw source row id before any normalization."
    },
    "_company_id": {
      "type": "string",
      "description": "Internal tenant/company identifier."
    },
    "_ingested_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of the ingestion run."
    },
    "_source_file": {
      "type": "string",
      "description": "Relative path of the source seed/file."
    },
    "_mapping_version": {
      "type": "string",
      "description": "Semver of the mapping artifact used (e.g. 'stripe.invoice@0.1.0')."
    },
    "_row_hash": {
      "type": "string",
      "description": "SHA-256 hex digest of the canonicalized row (all non-metadata fields)."
    }
  }
}
