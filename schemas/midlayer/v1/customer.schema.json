{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erp-data-ingestion/schemas/midlayer/v1/customer.schema.json",
  "title": "MidLayer Customer v1",
  "description": "Canonical mid-layer Customer schema, aligned with merge.dev Accounting Contact (Customer) common model.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "external_id",
    "_source_system",
    "_source_record_id",
    "_company_id",
    "_ingested_at",
    "_source_file",
    "_mapping_version",
    "_row_hash"
  ],
  "properties": {
    "external_id": {
      "type": "string",
      "description": "Source-provided identifier with prefix preserved (e.g. 'cus_...')."
    },
    "name": {
      "type": ["string", "null"]
    },
    "is_supplier": {
      "type": "boolean",
      "default": false
    },
    "is_customer": {
      "type": "boolean",
      "default": true
    },
    "email_address": {
      "type": ["string", "null"],
      "format": "email"
    },
    "tax_number": {
      "type": ["string", "null"]
    },
    "status": {
      "type": ["string", "null"],
      "enum": ["ACTIVE", "ARCHIVED", null]
    },
    "currency": {
      "type": ["string", "null"],
      "pattern": "^[A-Z]{3}$"
    },
    "remote_updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "phone_number": {
      "type": ["string", "null"]
    },
    "addresses": {
      "type": ["string", "null"],
      "description": "Minified JSON array of merge.dev Address objects."
    },
    "remote_was_deleted": {
      "type": "boolean",
      "default": false
    },
    "_unmapped": { "type": ["string", "null"] },
    "_source_system": { "type": "string" },
    "_source_record_id": { "type": "string" },
    "_company_id": { "type": "string" },
    "_ingested_at": { "type": "string", "format": "date-time" },
    "_source_file": { "type": "string" },
    "_mapping_version": { "type": "string" },
    "_row_hash": { "type": "string" }
  }
}
