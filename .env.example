# Credentials referenced by the Phase 1 seed README files. Copy to .env and fill
# in. Never commit .env.

# Stripe — read-only restricted key, needed for any real ingestion beyond the
# seed fixtures checked into seeds/stripe/**.
STRIPE_API_KEY=sk_test_replace_me

# Google Sheets — credentials (first match wins):
#   1) GOOGLE_SHEETS_SA_KEY — path to a service-account .json file, or inline JSON (single line), or
#   2) GOOGLE_APPLICATION_CREDENTIALS — path to a service-account JSON key file, or
#   3) Application Default Credentials — e.g. run:
#        gcloud auth application-default login
#      (uses your Google user; you need access to the spreadsheet). Use this when
#      your org blocks service account key creation (iam.disableServiceAccountKeyCreation).
# For 1–2, the service account must be granted Editor on any target sheet.
# In that service account's GCP project, enable APIs: Google Sheets API (required);
# Google Drive API if the client library needs it.
#
# If you use Application Default Credentials (`gcloud auth application-default login`),
# the default scopes are cloud-platform only. Sheets feeders need spreadsheet + drive;
# when you override --scopes, gcloud also requires cloud-platform in the same list:
#   gcloud auth application-default login --scopes=https://www.googleapis.com/auth/cloud-platform,https://www.googleapis.com/auth/spreadsheets,https://www.googleapis.com/auth/drive
# If gcloud warns those scopes will be blocked for the default OAuth client, use a
# service account key or your own OAuth client (see Google Cloud ADC troubleshooting).
#
# If the browser shows "This app is blocked" / "tried to access sensitive info":
# Google often blocks user OAuth for Sheets/Drive with gcloud's default client.
# Prefer GOOGLE_APPLICATION_CREDENTIALS or GOOGLE_SHEETS_SA_KEY (service account)
# and share the spreadsheet with that service account email as Editor.
GOOGLE_SHEETS_SA_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Google Sheets invoice feeder (seeds/generators/gsheets_invoice_feeder.py).
# Stripe-shaped feeder: appends fake invoices every INTERVAL seconds;
# point it at a sheet the service account has edit access to.
GSHEETS_FEEDER_SPREADSHEET_ID=1Ap858t1QMAnKaGNMq7_tIMhahORKohjxvTu5H2GhkUI
GSHEETS_FEEDER_WORKSHEET=invoices
GSHEETS_FEEDER_INTERVAL_SECONDS=60
GSHEETS_FEEDER_BATCH_SIZE=5

# Invoiced.com raw-dump feeder (seeds/generators/invoiced/).
# Simulates a recurring API pull from invoiced.com and lands Customers,
# Contacts, and Invoices into three worksheets on the same spreadsheet.
# See docs/sources/invoiced-data-format.md for the column contract.
# Falls back to GSHEETS_FEEDER_SPREADSHEET_ID when this is unset.
INVOICED_FEEDER_SPREADSHEET_ID=
INVOICED_FEEDER_WORKSHEET_CUSTOMERS=customers
INVOICED_FEEDER_WORKSHEET_CONTACTS=contacts
INVOICED_FEEDER_WORKSHEET_INVOICES=invoices
INVOICED_FEEDER_INTERVAL_SECONDS=30
INVOICED_FEEDER_INVOICES_PER_TICK=3
INVOICED_FEEDER_NEW_CUSTOMER_PROB=0.25
INVOICED_FEEDER_SECONDARY_CONTACT_PROB=0.15
INVOICED_FEEDER_CUSTOMER_MUTATE_PROB=0.1
INVOICED_FEEDER_LIFECYCLE_FLIP_TARGET=4

# Supabase — the target bucket for Phase 1 artifacts.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_BUCKET=midlayer-csv

# Supabase Storage S3 gateway — Phase 4 replayable artifacts for Mira.
SUPABASE_STORAGE_S3_BUCKET=mira
SUPABASE_STORAGE_S3_ENDPOINT_URL=
SUPABASE_STORAGE_S3_ACCESS_KEY_ID=
SUPABASE_STORAGE_S3_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_S3_REGION=us-east-1

# ClickHouse Cloud — Phase 4 analytics and observability sink.
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=phase4
CLICKHOUSE_SECURE=true

# Mira agent (Phase 2–3) — see docs/0003-phase2-3-midlayer-agent.md
OPENAI_API_KEY=
MIRA_OPENAI_MODEL=gpt-4o-mini
MIRA_RUN_ID=
MIRA_WORKSPACE=.mira_workspace
MIRA_JWT_SECRET=change-me-in-production
MIRA_DASHBOARD_BASE_URL=http://127.0.0.1:8090/dashboard
MIRA_ONBOARDING_TABLE=onboarding_runs

# Telegram bot (group onboarding)
TELEGRAM_BOT_TOKEN=
TELEGRAM_REQUIRE_MENTION=false
TELEGRAM_ALLOWLIST_USER_IDS=
TELEGRAM_CUSTOMER_USER_IDS=
TELEGRAM_FDE_USER_IDS=
MIRA_TG_SMART_POLICY=true
MIRA_TG_MIN_SECONDS_BETWEEN_REPLIES=3
MIRA_TG_MAX_REPLIES_PER_MINUTE=10
MIRA_TG_OPEN_QUESTION_WINDOW_MESSAGES=8
MIRA_TG_OPEN_QUESTION_WINDOW_SECONDS=900

# Optional research
TAVILY_API_KEY=

# Optional GitHub PR skill
GITHUB_TOKEN=
GITHUB_REPOSITORY=org/repo
