# Credentials referenced by the Phase 1 seed README files. Copy to .env and fill
# in. Never commit .env.

# Stripe — read-only restricted key, needed for any real ingestion beyond the
# seed fixtures checked into seeds/stripe/**.
STRIPE_API_KEY=sk_test_replace_me

# Google Sheets — service-account JSON key. Either:
#   1) inline the full JSON as a single-line string in GOOGLE_SHEETS_SA_KEY, or
#   2) set GOOGLE_APPLICATION_CREDENTIALS to a file path (standard GCP convention).
# The service account must be granted Editor on any target sheet.
GOOGLE_SHEETS_SA_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Google Sheets invoice feeder (tools/generators/gsheets_invoice_feeder.py).
# The feeder appends fake invoices every INTERVAL seconds; point it at a
# sheet the service account has edit access to.
GSHEETS_FEEDER_SPREADSHEET_ID=1Ap858t1QMAnKaGNMq7_tIMhahORKohjxvTu5H2GhkUI
GSHEETS_FEEDER_WORKSHEET=invoices
GSHEETS_FEEDER_INTERVAL_SECONDS=60
GSHEETS_FEEDER_BATCH_SIZE=5

# Supabase — the target bucket for Phase 1 artifacts.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_BUCKET=midlayer-csv
