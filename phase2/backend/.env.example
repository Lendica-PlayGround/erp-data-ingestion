# Copy to .env and fill in. Never commit .env.

# OpenAI API key for the exploration agent.
OPENAI_API_KEY=sk-proj-replace_me

# Model to use (default gpt-4o).
PHASE2_MODEL=gpt-4o

# Where agent artifacts are written. Relative paths are resolved from
# phase2/backend/. Default points at the shared phase2/output folder that
# is auto-committed to the outer git repo.
PHASE2_OUTPUT_DIR=../output

# Where user uploads are stored (per-session subfolders).
PHASE2_UPLOAD_DIR=./uploads

# CORS origin for the Next.js dev server.
PHASE2_FRONTEND_ORIGIN=http://localhost:3000
